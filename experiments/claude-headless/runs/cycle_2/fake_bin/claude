#!/usr/bin/env bash
# emit a long output for plan, short for the rest
if [[ "$*" == *"CURRENT STEP: plan"* ]]; then
  long=$(python3 -c 'print("x" * 10000)')
  echo "{\"is_error\": false, \"result\": \"$long\", \"num_turns\": 2}"
else
  echo '{"is_error": false, "result": "short", "num_turns": 2}'
fi
