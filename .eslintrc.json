{
  "env": { "browser": true, "es6": true },
  "parserOptions": { "ecmaVersion": 2020 },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "eqeqeq": "warn",
    "no-redeclare": "error",
    "no-unreachable": "error",
    "no-constant-condition": "warn",
    "no-empty": "warn",
    "no-self-assign": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-irregular-whitespace": "error",
    "use-isnan": "error",
    "valid-typeof": "error"
  }
}
